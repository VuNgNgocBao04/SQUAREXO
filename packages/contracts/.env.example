# Oasis Sapphire
OASIS_RPC_URL=https://testnet.sapphire.oasis.io
OASIS_MAINNET_RPC_URL=https://sapphire.oasis.io

# Private key used for deployment only (64-hex, optionally with 0x prefix)
DEPLOYER_PRIVATE_KEY=

# Backend signer wallet address (receives BACKEND_SIGNER_ROLE in constructor)
BACKEND_SIGNER_ADDRESS=

# Optional contract timeouts (seconds)
MATCH_JOIN_TIMEOUT_SECONDS=900
MATCH_RESULT_TIMEOUT_SECONDS=3600

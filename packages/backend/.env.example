# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL / Prisma
DATABASE_URL=postgresql://squarexo:squarexo@localhost:5432/squarexo?schema=public

# Public URL for server (used in socket.io, etc)
PUBLIC_BASE_URL=http://localhost:3000

# Socket.io Configuration
RECONNECT_TIMEOUT_MS=30000
DEDUPE_WINDOW_MS=15000
ROOM_SWEEP_INTERVAL_MS=5000

# JWT Configuration
# IMPORTANT: Generate a strong secret key in production
# Minimum 32 characters recommended
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-here-at-least-32-characters-long

# Token Expiration Times
# Examples: "7d", "24h", "30d", "1h"
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Socket auth policy
# Production recommended: REQUIRE_SOCKET_JWT=true and ALLOW_GUEST_SOCKET_IN_DEV=false
REQUIRE_SOCKET_JWT=
ALLOW_GUEST_SOCKET_IN_DEV=true

# Oasis Sapphire blockchain integration
OASIS_RPC_URL=https://testnet.sapphire.oasis.io
BACKEND_SIGNER_PRIVATE_KEY=
CONTRACT_ADDRESS=

# Blockchain submit reliability
BLOCKCHAIN_SUBMIT_RETRY_MAX_ATTEMPTS=3
BLOCKCHAIN_SUBMIT_BASE_DELAY_MS=750
BLOCKCHAIN_TX_CONFIRMATIONS=1
BLOCKCHAIN_SUBMIT_TIMEOUT_MS=45000

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL / Prisma
DATABASE_URL=postgresql://squarexo:squarexo@localhost:5432/squarexo?schema=public

# Public URL for server (used in socket.io, etc)
PUBLIC_BASE_URL=http://localhost:3000

# Socket.io Configuration
RECONNECT_TIMEOUT_MS=30000
DEDUPE_WINDOW_MS=15000
ROOM_SWEEP_INTERVAL_MS=5000

# JWT Configuration
# IMPORTANT: Generate a strong secret key in production
# Minimum 32 characters recommended
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-here-at-least-32-characters-long

# Token Expiration Times
# Examples: "7d", "24h", "30d", "1h"
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Oasis Sapphire blockchain integration
OASIS_RPC_URL=https://testnet.sapphire.oasis.io
OASIS_RPC_FALLBACK_URLS=https://sapphire-testnet.gateway.tenderly.co,https://testnet.sapphire.oasis.dev
OASIS_EXPECTED_CHAIN_ID=23295
BACKEND_SIGNER_PRIVATE_KEY=
CONTRACT_ADDRESS=
BLOCKCHAIN_TX_TIMEOUT_MS=45000

# Optional: protect /api/history/sync in production
# HISTORY_SYNC_API_KEY must be at least 24 chars
HISTORY_SYNC_API_KEY=
